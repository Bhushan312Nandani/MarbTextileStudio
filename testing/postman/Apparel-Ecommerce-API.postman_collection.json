{
  "info": {
    "name": "Apparel E-Commerce API",
    "description": "Covers every route currently scaffolded in backend/src/routes. Endpoints return placeholder \"To be implemented\" responses until each owner fills in their service layer -- see docs/INTERN_WORKFLOW_GUIDE.md for who owns what.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Public - Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/public/auth/register", "host": ["{{baseUrl}}"], "path": ["public", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"email\": \"test.user@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/public/auth/login", "host": ["{{baseUrl}}"], "path": ["public", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@marbtextile.test\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Public - Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/public/products", "host": ["{{baseUrl}}"], "path": ["public", "products"] }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/public/products/search?q=shirt",
              "host": ["{{baseUrl}}"],
              "path": ["public", "products", "search"],
              "query": [{ "key": "q", "value": "shirt" }]
            }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/public/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["public", "products", ":id"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_PRODUCT_ID" }]
            }
          }
        }
      ]
    },
    {
      "name": "Public - Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/public/categories", "host": ["{{baseUrl}}"], "path": ["public", "categories"] }
          }
        }
      ]
    },
    {
      "name": "Admin - Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/products", "host": ["{{baseUrl}}"], "path": ["admin", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Product\",\n  \"description\": \"Description here\"\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products", ":id"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_PRODUCT_ID" }]
            },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated title\"\n}" }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products", ":id"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_PRODUCT_ID" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Categories",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/categories", "host": ["{{baseUrl}}"], "path": ["admin", "categories"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Category\"\n}" }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "categories", ":id"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_CATEGORY_ID" }]
            },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Renamed Category\"\n}" }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "categories", ":id"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_CATEGORY_ID" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/orders", "host": ["{{baseUrl}}"], "path": ["admin", "orders"] }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/orders/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders", ":id", "status"],
              "variable": [{ "key": "id", "value": "REPLACE_WITH_ORDER_ID" }]
            },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SHIPPED\"\n}" }
          }
        }
      ]
    }
  ]
}
